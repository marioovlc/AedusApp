<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.aedusapp.controllers.incidencias.IncidenciasController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="Gestión de Incidencias">
        <font>
            <Font size="24.0" />
        </font>
    </Label>

    <HBox spacing="20.0" VBox.vgrow="ALWAYS">
        <!-- Formulario de Creación -->
        <!-- Formulario de Creación -->
        <VBox spacing="15.0" styleClass="content-panel" minWidth="350">
            <Label text="Nueva Incidencia" styleClass="h2" />
            
            <javafx.scene.layout.GridPane hgap="10" vgap="10">
                <columnConstraints>
                    <javafx.scene.layout.ColumnConstraints hgrow="NEVER" minWidth="80"/>
                    <javafx.scene.layout.ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>
                
                <Label text="Título:" styleClass="input-label" javafx.scene.layout.GridPane.rowIndex="0" javafx.scene.layout.GridPane.columnIndex="0"/>
                <TextField fx:id="tituloField" promptText="Resumen del problema" javafx.scene.layout.GridPane.rowIndex="0" javafx.scene.layout.GridPane.columnIndex="1"/>
                
                <Label text="Aula:" styleClass="input-label" javafx.scene.layout.GridPane.rowIndex="1" javafx.scene.layout.GridPane.columnIndex="0"/>
                <TextField fx:id="aulaField" promptText="Nº Aula" javafx.scene.layout.GridPane.rowIndex="1" javafx.scene.layout.GridPane.columnIndex="1"/>

                <Label text="Tipo de Aula:" styleClass="input-label" javafx.scene.layout.GridPane.rowIndex="2" javafx.scene.layout.GridPane.columnIndex="0"/>
                <ComboBox fx:id="aulaTipoCombo" prefWidth="200.0" promptText="Seleccionar..." javafx.scene.layout.GridPane.rowIndex="2" javafx.scene.layout.GridPane.columnIndex="1"/>

                <Label text="Categoría:" styleClass="input-label" javafx.scene.layout.GridPane.rowIndex="3" javafx.scene.layout.GridPane.columnIndex="0"/>
                <ComboBox fx:id="categoriaCombo" prefWidth="200.0" promptText="Seleccionar..." javafx.scene.layout.GridPane.rowIndex="3" javafx.scene.layout.GridPane.columnIndex="1"/>
            </javafx.scene.layout.GridPane>

            <Label text="Descripción:" styleClass="input-label"/>
            <TextArea fx:id="descripcionField" prefHeight="120.0" promptText="Detalles de la incidencia..." wrapText="true" />
            
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <Button fx:id="adjuntarImagenBtn" mnemonicParsing="false" onAction="#handleAdjuntarImagen" text="Adjuntar Imagen 📎" styleClass="action-button" />
                <Label fx:id="imagenLabel" text="" textFill="#94a3b8" wrapText="true" HBox.hgrow="ALWAYS" />
            </HBox>
            
            <Button mnemonicParsing="false" onAction="#handleCrearIncidencia" text="Crear Ticket" styleClass="action-button, primary" maxWidth="Infinity" />
            <Label fx:id="statusLabel" textFill="RED" wrapText="true" />
        </VBox>

        <!-- Lista de Incidencias -->
        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
            <Label text="Mis Tickets">
                <font>
                    <Font name="System Bold" size="16.0" />
                </font>
            </Label>
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                <content>
                    <VBox fx:id="incidenciasContainer" spacing="10.0">
                        <padding>
                            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                        </padding>
                    </VBox>
                </content>
            </ScrollPane>
        </VBox>
    </HBox>
</VBox>
