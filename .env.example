# ==========================================
# AEDUS APP - ARCHIVO DE ENTORNO DE EJEMPLO
# ==========================================
# Crea una copia de este archivo como ".env" 
# e introduce tus valores reales.
# ==========================================

# Módulo 1: Base de Datos (Neon / PostgreSQL)
DB_URL=jdbc:postgresql://<tu-host-neon>:5432/<nombre-db>?sslmode=require
DB_USER=tu_usuario
DB_PASS=tu_password
DB_SCHEMA=gestion_incidencias, public, neon_auth
DB_POOL_MAX=15

# Módulo 2: Subida de Imágenes (Cloudinary)
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# Módulo 3: Inteligencia Artificial (Groq)
AI_API_URL=https://api.groq.com/openai/v1/chat/completions
AI_API_KEY=tu_api_key_gsk
AI_MODEL=llama-3.3-70b-versatile

# Módulo 4: Propiedades de la Ventana (Opcional)
APP_NAME=Aedus Local
APP_WIDTH=600
APP_HEIGHT=400
